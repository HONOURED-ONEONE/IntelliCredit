# For Production (Streamlit Cloud connecting to Railway)
API_URL=https://intellicredit-live.up.railway.app

# For Local Dev (API_HOST/API_PORT are used as fallbacks if API_URL is unset)
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501

# Default should be local_uploads for production
# Set to 'mock' for local-only offline testing if desired.
PROVIDER_MODE=local_uploads
SEARCH_PROVIDER=mock

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PPLX_API_KEY=
TAVILY_API_KEY=
SERPAPI_API_KEY=
BING_SUBSCRIPTION_KEY=

DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_HTTP_PATH=
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_CATALOG=
DATABRICKS_SCHEMA=